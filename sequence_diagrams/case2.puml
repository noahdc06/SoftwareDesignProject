@startuml case2_start_pve
actor User
participant UI
participant "CampaignController" as Controller
participant "CampaignService" as Service
participant "Party" as Party
database DB

User -> UI : select "Start PvE"
UI -> Controller : startCampaign(heroClass)

Controller -> Service : createCampaign(heroClass)
Service -> Party : createHero()

Service -> DB : saveCampaign()
DB --> Service : ok

Service --> Controller : campaign
Controller -> UI : show campaign view
@enduml
