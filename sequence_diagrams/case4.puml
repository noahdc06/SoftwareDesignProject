@startuml
actor User
participant InnGUI
participant InnController
participant InnService
database DB

== Purchase Item ==

User -> InnGUI : Buy Item
activate InnGUI

InnGUI -> InnController : purchaseItem(itemID)
activate InnController

InnController -> InnService : processPurchase(itemID)
activate InnService

InnService -> DB : checkGold(userID)
activate DB
DB --> InnService : currentGold
deactivate DB

alt sufficient gold
    InnService -> DB : updateGold() & updateInventory()
    activate DB
    DB --> InnService : success
    deactivate DB

    InnService --> InnController : purchaseSuccess
    InnController --> InnGUI : refreshPartyStats()
else insufficient gold
    InnService --> InnController : purchaseFailed
    InnController --> InnGUI : showError("Not enough gold")
end

deactivate InnService
deactivate InnController
deactivate InnGUI


== Recruit Hero ==

User -> InnGUI : Recruit Hero
activate InnGUI

InnGUI -> InnController : recruitHero(heroID)
activate InnController

InnController -> InnService : processRecruitment(heroID)
activate InnService

InnService -> DB : checkGoldAndPartySize()
activate DB
DB --> InnService : gold, partySize
deactivate DB

alt enough gold AND partySize < 5
    InnService -> DB : updateGold() & addHeroToParty()
    activate DB
    DB --> InnService : success
    deactivate DB

    InnService --> InnController : recruitSuccess
    InnController --> InnGUI : refreshPartyStats()
else not enough gold OR party full
    InnService --> InnController : recruitFailed
    InnController --> InnGUI : showError("Cannot recruit hero")
end

deactivate InnService
deactivate InnController
deactivate InnGUI

@enduml