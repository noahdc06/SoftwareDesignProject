@startuml case3_battle
actor User
participant UI
participant "BattleController" as Controller
participant "BattleService" as Service
participant "TurnManager" as Turn
participant "Unit" as Unit

UI -> Controller : startBattle(party, enemies)
Controller -> Service : initializeBattle()

loop turns
    Service -> Turn : nextUnit()
    Turn --> Service : currentUnit

    Service -> UI : show actions
    User -> UI : choose action

    UI -> Controller : performAction()
    Controller -> Service : executeAction()

    Service -> Unit : applyDamage()/defend()
    Unit --> Service : updated stats
end

Service -> Controller : battleResult
Controller -> UI : display results
@enduml
