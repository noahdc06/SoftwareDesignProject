@startuml case1_login
actor User
participant "GUI" as UI
participant "AuthController" as Auth
participant "UserService" as Service
database "Database" as DB

User -> UI : enter username/password
UI -> Auth : login(username, password)

Auth -> Service : validateUser()
Service -> DB : fetchUser(username)

DB --> Service : user data / null
Service --> Auth : valid / invalid

alt valid
    Auth -> UI : loginSuccess()
    UI -> User : show dashboard
else invalid
    Auth -> UI : loginFailed()
    UI -> User : show error
end
@enduml
