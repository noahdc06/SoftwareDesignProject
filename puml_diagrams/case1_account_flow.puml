@startuml
actor User
participant LoginPage
participant CreateProfilePage
participant UserDAO
database DB
participant HomePage

== Create Account ==

User -> LoginPage : Click "Create Account"
LoginPage -> CreateProfilePage : open()

User -> CreateProfilePage : Enter username and password
activate CreateProfilePage
CreateProfilePage -> UserDAO : createUser(username, password)
activate UserDAO

UserDAO -> DB : SELECT username FROM users WHERE username=?
activate DB
DB --> UserDAO : exists / not exists
deactivate DB

alt username not taken
    UserDAO -> DB : INSERT INTO users(username, password, party_level, room_count)
    activate DB
    DB --> UserDAO : success
    deactivate DB
    UserDAO --> CreateProfilePage : created
    CreateProfilePage --> User : Show success message
else username exists
    UserDAO --> CreateProfilePage : failed
    CreateProfilePage --> User : Show "Username taken"
end

deactivate UserDAO
deactivate CreateProfilePage

== Login ==

User -> LoginPage : Enter username and password
activate LoginPage
LoginPage -> UserDAO : login(username, password)
activate UserDAO
UserDAO -> DB : SELECT * FROM users WHERE username=? AND password=?
activate DB
DB --> UserDAO : matching row / no row
deactivate DB

alt credentials valid
    UserDAO --> LoginPage : Profile
    LoginPage -> HomePage : open(profile)
    HomePage --> User : Show main menu
else credentials invalid
    UserDAO --> LoginPage : null
    LoginPage --> User : Show invalid login message
end

deactivate UserDAO
deactivate LoginPage
@enduml
