@startuml
actor User
participant HomePage
participant PvECampaign
participant BattlePage
participant InnPage
participant UserDAO
database DB

== Start PvE ==

User -> HomePage : Click "Enter PvE"
activate HomePage
HomePage -> PvECampaign : determineCurrentRoomType()
activate PvECampaign

alt roomCount == 1
    PvECampaign --> HomePage : INN
    HomePage -> BattlePage : startPvEFlow()
    BattlePage -> InnPage : open first room
else battle room rolled
    PvECampaign --> HomePage : BATTLE
    HomePage -> BattlePage : open battle
else campaign complete
    PvECampaign --> HomePage : CAMPAIGN_COMPLETE
    HomePage --> User : Show completion popup
end

deactivate PvECampaign
deactivate HomePage

== After Winning Battle ==

BattlePage -> PvECampaign : completeBattle()
activate PvECampaign
PvECampaign --> BattlePage : partyLevel +1, roomCount +1
deactivate PvECampaign

BattlePage -> UserDAO : updateProgress(profile)
activate UserDAO
UserDAO -> DB : UPDATE users SET party_level=?, room_count=?
activate DB
DB --> UserDAO : success
deactivate DB
deactivate UserDAO

BattlePage -> BattlePage : startPvEFlow()

== At Inn ==

InnPage -> PvECampaign : completeInnRoomAndSave()
activate PvECampaign
PvECampaign -> UserDAO : updateProgress(profile)
activate UserDAO
UserDAO -> DB : UPDATE users SET party_level=?, room_count=?
activate DB
DB --> UserDAO : success
deactivate DB
deactivate UserDAO
deactivate PvECampaign

InnPage -> BattlePage : startPvEFlow()
@enduml
