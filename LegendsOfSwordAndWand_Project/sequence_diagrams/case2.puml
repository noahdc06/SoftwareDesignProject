@startuml

actor User
participant GUI
participant PvECampaign
participant BattleService
participant ScoreService
database DB

== Start Campaign ==

User -> GUI : startCampaign()
activate GUI
GUI -> PvECampaign : startCampaign()
activate PvECampaign
deactivate PvECampaign
deactivate GUI

User -> GUI : selectHeroClass()
activate GUI
GUI -> PvECampaign : createHero()
activate PvECampaign
deactivate PvECampaign
deactivate GUI

== During Campaign ==

User -> GUI : nextRoom()
activate GUI
GUI -> PvECampaign : nextRoom()
activate PvECampaign

alt Battle Room
    PvECampaign -> BattleService : startBattle()
    activate BattleService
    BattleService --> GUI : battleResults(xp, gold)
    deactivate BattleService
else Inn Room
    PvECampaign --> GUI : showInnView()
end

deactivate PvECampaign
deactivate GUI

== After 30 Rooms ==

GUI -> PvECampaign : checkCompletion()
activate PvECampaign
PvECampaign -> ScoreService : calculateScore()
activate ScoreService
ScoreService -> DB : saveScore()
activate DB
deactivate DB
deactivate ScoreService
deactivate PvECampaign

GUI -> DB : getRanking()
activate DB
DB --> GUI : ranking
deactivate DB

== Party Limit ==

GUI -> DB : getStoredParties()
activate DB
DB --> GUI : parties
deactivate DB

alt 5 Parties
    GUI -> User : promptReplaceParty()
    GUI -> DB : deleteParty()
    activate DB
    deactivate DB
end

@enduml