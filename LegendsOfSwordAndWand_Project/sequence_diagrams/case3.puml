@startuml
actor User
participant GUI
participant BattleController
participant BattleService
participant Attacker as UnitA
participant Defender as UnitD
database DB

== Player Turn ==

User -> GUI : Select Action (Attack)
activate GUI

GUI -> BattleController : executeAction(action, target)
activate BattleController

BattleController -> BattleService : processAction(action, target)
activate BattleService

BattleService -> UnitA : getAttack()
UnitA --> BattleService : attackValue

BattleService -> UnitD : getDefense()
UnitD --> BattleService : defenseValue

BattleService -> UnitD : applyDamage(attack - defense)
UnitD --> BattleService : updatedHP

BattleService --> BattleController : updatedBattleState
deactivate BattleService

BattleController --> GUI : refreshStats()
deactivate BattleController
deactivate GUI

== Check End Condition ==

BattleController -> BattleService : checkBattleEnd()
activate BattleService

alt one party defeated
    BattleService -> DB : calculateExpAndGold()
    activate DB
    DB --> BattleService : exp, gold
    deactivate DB

    BattleService --> BattleController : battleResult
    BattleController --> GUI : showBattleResult()
else battle continues
    BattleService --> BattleController : nextTurn()
end

deactivate BattleService

@enduml